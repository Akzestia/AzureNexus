prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_log_internal_test_actions
Description: Abseil log_internal_test_actions library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_core_headers = head, absl_log_entry = head, absl_log_severity = head, absl_strings = head, absl_time = head
Libs: -L${libdir}  -labsl_log_internal_test_actions 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
