prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_spinlock_test_common
Description: Abseil spinlock_test_common library
URL: https://abseil.io/
Version: head
Requires: absl_base = head, absl_config = head, absl_base_internal = head, absl_core_headers = head, absl_synchronization = head
Libs: -L${libdir}  -labsl_spinlock_test_common 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX -Wno-deprecated-declarations -Wno-missing-declarations -Wno-self-move -Wno-sign-compare -Wno-unused-function -Wno-unused-parameter -Wno-unused-private-field
