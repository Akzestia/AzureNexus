prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_spy_hash_state
Description: Abseil spy_hash_state library
URL: https://abseil.io/
Version: head
Requires: absl_hash = head, absl_strings = head, absl_str_format = head
Libs: -L${libdir}  
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
