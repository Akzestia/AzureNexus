prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_scoped_mock_log
Description: Abseil scoped_mock_log library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_log_entry = head, absl_log_severity = head, absl_log_sink = head, absl_log_sink_registry = head, absl_raw_logging_internal = head, absl_strings = head
Libs: -L${libdir}  -labsl_scoped_mock_log 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
