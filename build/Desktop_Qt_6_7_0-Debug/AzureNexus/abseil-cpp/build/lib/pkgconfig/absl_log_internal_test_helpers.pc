prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_log_internal_test_helpers
Description: Abseil log_internal_test_helpers library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_log_globals = head, absl_log_initialize = head, absl_log_internal_globals = head, absl_log_severity = head
Libs: -L${libdir}  -labsl_log_internal_test_helpers 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
