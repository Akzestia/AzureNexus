prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_status_matchers
Description: Abseil status_matchers library
URL: https://abseil.io/
Version: head
Requires: absl_base = head, absl_status = head, absl_statusor = head, absl_strings = head
Libs: -L${libdir}  -labsl_status_matchers 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
