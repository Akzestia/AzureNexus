prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_random_internal_explicit_seed_seq
Description: Abseil random_internal_explicit_seed_seq library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_endian = head
Libs: -L${libdir}  
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
