prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_cord_rep_test_util
Description: Abseil cord_rep_test_util library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_cord_internal = head, absl_raw_logging_internal = head, absl_strings = head
Libs: -L${libdir}  
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX -Wno-deprecated-declarations -Wno-missing-declarations -Wno-self-move -Wno-sign-compare -Wno-unused-function -Wno-unused-parameter -Wno-unused-private-field
