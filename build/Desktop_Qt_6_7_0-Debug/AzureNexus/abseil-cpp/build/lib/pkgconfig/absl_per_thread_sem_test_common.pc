prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_per_thread_sem_test_common
Description: Abseil per_thread_sem_test_common library
URL: https://abseil.io/
Version: head
Requires: absl_synchronization = head, absl_base = head, absl_config = head, absl_strings = head, absl_time = head
Libs: -L${libdir}  -labsl_per_thread_sem_test_common 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX -Wno-deprecated-declarations -Wno-missing-declarations -Wno-self-move -Wno-sign-compare -Wno-unused-function -Wno-unused-parameter -Wno-unused-private-field
