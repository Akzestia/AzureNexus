prefix=/usr/local
exec_prefix=${prefix}
libdir=/usr/local/lib
includedir=/usr/local/include

Name: absl_bad_optional_access
Description: Abseil bad_optional_access library
URL: https://abseil.io/
Version: head
Requires: absl_config = head, absl_raw_logging_internal = head
Libs: -L${libdir}  -labsl_bad_optional_access 
Cflags: -I${includedir} -Wnon-virtual-dtor -DNOMINMAX
